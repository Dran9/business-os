# ============================================
# Business OS — Variables de entorno
# ============================================

# --- MySQL (Hostinger) ---
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

# --- Auth ---
JWT_SECRET=
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# --- WhatsApp Cloud API ---
WA_TOKEN=
WA_PHONE_ID=
WABA_ID=
WA_VERIFY_TOKEN=

# --- LLM ---
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# --- Google Vision (OCR) ---
GOOGLE_VISION_API_KEY=

# --- Google Sheets (exportación) ---
GOOGLE_SHEETS_ID=
# Opción recomendada: Service Account
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Opción alternativa: OAuth refresh token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Tope de logs de conversación por export para proteger rendimiento
GOOGLE_SHEETS_MAX_CONVERSATION_ROWS=60000

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- Pushinator ---
PUSHINATOR_TOKEN=
PUSHINATOR_CHANNEL_ID=

# --- Agenda 4.0 Bridge ---
AGENDA_API_URL=https://agenda.danielmaclean.com
AGENDA_API_TOKEN=

# --- Server ---
PORT=3000
NODE_ENV=production
